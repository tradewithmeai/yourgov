{
  "_comment": "Copy this file to config.json and fill in real values. config.json is gitignored. Do NOT commit secrets.",
  "poll_interval_seconds": 60,

  "telegram": {
    "telegram_bot_token": "PUT-YOUR-BOT-TOKEN-HERE",
    "allowed_chat_ids": [-1001234567890],
    "allowed_chat_names": ["mygov-feedback"],
    "allowed_usernames": ["neil_example"],
    "max_message_chars": 4000
  },

  "email": {
    "_comment": "Use an app password / app-specific token, never your main password. Read-only access is enough.",
    "imap_host": "imap.example.com",
    "imap_port": 993,
    "username": "feedback@example.com",
    "password": "PUT-APP-PASSWORD-HERE",
    "folder": "INBOX",
    "channel_name": "mygov-feedback-email",
    "allowed_senders": ["someone@example.com"],
    "allowed_recipients": ["feedback@example.com"],
    "max_message_chars": 4000
  },

  "whatsapp": {
    "_comment": "Consumes JSONL exported by the linked-device bridge. Non-official protocol; may break.",
    "jsonl_path": "incoming-pdfs/messages.jsonl",
    "channel_name": "mygov-feedback-whatsapp",
    "allowed_chat_jids": ["123456789-987654321@g.us"],
    "allowed_sender_jids": ["447700900000@s.whatsapp.net"],
    "max_message_chars": 4000
  }
}
